{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDFPPT",
  "version": "0.1.0",
  "identifier": "dev.seokju.pdfppt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDFPPT",
        "width": 980,
        "height": 720,
        "minWidth": 760,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../../../build/opendataloader/opendataloader-pdf-cli.jar"
    ],
    "externalBin": []
  }
}
